---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout>
    <Hero />

    <section id="experience" class="w-full flex flex-col gap-8 mb-16 sm:mb-24">
        <h2 class="text-2xl leading-tight font-serif font-medium sm:text-2xl sm:leading-tight text-[rgb(var(--color-text-main))]">Work Experience</h2>
        
        <div class="space-y-12">
            <!-- Triumph International -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2025 – today</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">Triumph International</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">SEO Content Manager</p>
                    <p class="text-[rgb(var(--color-text-main))]">I manage end-to-end content creation and optimization for international websites across 15+ markets and languages, develop governance frameworks ensuring brand consistency, lead cross-functional teams to scale content operations, and implement NLP technologies to optimize content strategies.</p>
                </div>
            </div>

            <!-- NUR Digital Marketing -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2022 – 2025</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">NUR Digital Marketing</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">SEO Specialist (Tech Lead)</p>
                    <p class="text-[rgb(var(--color-text-main))]">I managed technical and content SEO audits for enterprise-level clients, developed comprehensive strategies improving organic traffic and conversions, led R&D initiatives in AI-SEO technology, and provided leadership to junior team members while coordinating with cross-functional departments.</p>
                </div>
            </div>

            <!-- TeseCom -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2020 – 2022</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">TeseCom – Digital Marketing Agency</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">SEO Specialist</p>
                    <p class="text-[rgb(var(--color-text-main))]">I led R&D initiatives in AI-SEO technology, created optimized content strategies based on competitive analysis, delivered regular performance reports with clear ROI measurements, and established successful collaboration with the PPC department to align keyword strategy across all channels.</p>
                </div>
            </div>

            <!-- Brand-On -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2019 – 2020</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">Brand-On Communication and Marketing Agency</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">SEO Specialist</p>
                    <p class="text-[rgb(var(--color-text-main))]">I specialized in eCommerce SEO optimization focusing on product architecture, executed on-page and off-page tactics to improve rankings, developed targeted keyword strategies based on market research, and built strong client relationships through effective communication and consistent results.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="education" class="w-full flex flex-col gap-8 mb-16 sm:mb-24">
        <h2 class="text-2xl leading-tight font-serif font-medium sm:text-2xl sm:leading-tight text-[rgb(var(--color-text-main))]">Education</h2>
        
        <div class="space-y-12">
            <!-- Fondazione Italia USA -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2021 – 2022</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">Fondazione Italia USA</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">Global Marketing, Communication & Made in Italy</p>
                    <p class="text-[rgb(var(--color-text-main))]">Scholarship regarding the principles of global marketing and specifically the movement and export of Made in Italy goods.</p>
                </div>
            </div>

            <!-- 24ORE Business School -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2021</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">24ORE Business School</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">Data Analytics and Marketing Intelligence</p>
                    <p class="text-[rgb(var(--color-text-main))]">I studied the strategies, methodologies and automations of advanced representation of large data sets.</p>
                </div>
            </div>

            <!-- IED -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2020 – 2021</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">IED Istituto Europeo di Design</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">E-commerce: Design and Management</p>
                    <p class="text-[rgb(var(--color-text-main))]">I learned the advanced concepts of proper e-commerce management, with a focus on marketing aspects.</p>
                </div>
            </div>

            <!-- Istituto Modartech -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2018 – 2019</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">Istituto Modartech</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">Web Design Technical Diploma</p>
                    <p class="text-[rgb(var(--color-text-main))]">I learned the fundamentals of web design, UX/UI principles, and front-end development techniques.</p>
                </div>
            </div>
            
            <!-- University of Pisa -->
            <div class="flex flex-col md:flex-row gap-4">
                <div class="md:w-1/4">
                    <p class="text-[rgb(var(--color-text-muted))] opacity-80">2013 – 2017</p>
                </div>
                <div class="md:w-3/4">
                    <h3 class="text-xl font-medium mb-2 text-[rgb(var(--color-text-main))]">University of Pisa</h3>
                    <p class="text-lg mb-2 text-[rgb(var(--color-text-muted))] opacity-80">B.A. in Clinical Psychology</p>
                    <p class="text-[rgb(var(--color-text-main))]">I studied the fundamentals of psychology with a focus on clinical applications and research methodologies.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
